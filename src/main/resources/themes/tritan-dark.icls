      </value>
    </option>

    <option name="DIFF_DELETED">
      <value>
        <option name="BACKGROUND"  value="2A0A0A"/>  <!-- dark red for "removed" -->
      </value>
    </option>

    <option name="DIFF_MODIFIED">
      <value>
        <option name="BACKGROUND"  value="2A1500"/>  <!-- dark orange for "changed" -->
      </value>
    </option>

    <option name="DIFF_CONFLICT">
      <value>
        <option name="BACKGROUND"  value="251818"/>
      </value>
    </option>

  </attributes>

</scheme>
