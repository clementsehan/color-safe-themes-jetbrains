        <option name="EFFECT_COLOR"       value="FF4444"/>
        <option name="EFFECT_TYPE"        value="1"/>  <!-- 1 = box/border -->
        <option name="ERROR_STRIPE_COLOR" value="FF4444"/>
      </value>
    </option>

    <!-- DEPRECATED: muted + strikethrough (structural encoding) -->
    <option name="DEPRECATED_ATTRIBUTES">
      <value>
        <option name="FOREGROUND"         value="9A8878"/>
        <option name="EFFECT_COLOR"       value="9A8878"/>
        <option name="EFFECT_TYPE"        value="3"/>  <!-- 3 = strikethrough -->
