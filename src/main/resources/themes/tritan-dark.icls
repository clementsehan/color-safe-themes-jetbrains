<?xml version="1.0" encoding="UTF-8"?>
<scheme name="Tritan Dark" version="142" parent_scheme="Darcula">

  <!--
    Tritan Dark (CVD) — Editor Color Scheme
    Designed for Tritanopia (Blue Cone Deficiency / Blue-Yellow Color Blindness)

    Core axis: Hot Pink (#FF216A) vs Cyan (#01D4F9).
    Both are safe for tritanopia: #FF216A loses its S-cone (blue) component → appears red
    (high L, low M); #01D4F9 loses its S-cone → appears bright green (low L, high M).
    These sit at opposite ends of the L-M axis, maximally distinguishable without S-cones.
    In normal vision they read as hot pink vs electric cyan — clearly distinct.
    Font-style encoding (bold keywords, italic parameters/comments) provides an additional
    colour-independent cue.
    Errors:   Bright Red (#FF4444) + squiggly underline + bold (triple encoding).
    Warnings: Orange (#FFA040) squiggly underline only (text color unchanged).
    Comments: Italic — distinct font style regardless of color perception.
    Keywords: Bold — structurally distinct regardless of color perception.

    JS-plugin Darcula overrides added explicitly:
      JS.GLOBAL_FUNCTION / JS.INSTANCE_MEMBER_FUNCTION → was #FFC66D yellow → salmon
      JS.GLOBAL_VARIABLE                                → was #9876AA purple → light rose
      JS.LOCAL_VARIABLE                                 → was #A9B7C6 blue-gray → warm white
      JS.REGEXP                                         → was #6897BB blue → peach
      TS.TYPE_GUARD background                          → was #223C23 dark green → dark warm

    All text-on-background contrast ratios verified ≥ 4.5:1 (WCAG AA).

    Contrast calculations against editor bg #1C1A1A (L ≈ 0.011):
      #E8E4E0  → 13.4:1   #FF4455  →  5.8:1   #FFAA88  →  8.6:1
      #E09090  →  6.1:1   #FFCCAA  → 10.8:1   #FF8833  →  7.2:1
      #E0B0B0  →  8.3:1   #FFA040  →  8.1:1   #FF4444  →  5.5:1
      #9CA090  →  5.8:1   #B07878  →  4.8:1   #DDA0A0  →  7.6:1
  -->

  <!-- ═══════════════════════════════════════════════════
       GLOBAL COLORS
       ═══════════════════════════════════════════════════ -->
  <colors>
    <!-- Core editor surface -->
    <option name="BACKGROUND"                          value="1C1A1A"/>
    <option name="FOREGROUND"                          value="E8E4E0"/>
    <option name="CARET_COLOR"                         value="FF216A"/>
    <option name="CARET_ROW_COLOR"                     value="281E1E"/>
    <option name="READONLY_BACKGROUND"                 value="181616"/>
    <option name="READONLY_FRAGMENT_BACKGROUND"        value="221E1E"/>

    <!-- Gutter -->
    <option name="GUTTER_BACKGROUND"                   value="1A1818"/>
    <option name="LINE_NUMBERS_COLOR"                  value="9A7878"/>
    <option name="LINE_NUMBER_ON_CARET_ROW_COLOR"      value="C8B8A8"/>

    <!-- Selection -->
    <option name="SELECTION_BACKGROUND"                value="3A2020"/>
    <option name="SELECTION_FOREGROUND"                value="E8E4E0"/>

    <!-- Right margin / guide lines -->
    <option name="RIGHT_MARGIN_COLOR"                  value="2E2222"/>
    <option name="INDENT_GUIDE"                        value="2E2222"/>
    <option name="SELECTED_INDENT_GUIDE"               value="FF216A"/>
    <option name="WHITESPACE"                          value="3A2A2A"/>
    <option name="METHOD_SEPARATORS_COLOR"             value="2E2222"/>
    <option name="TEARLINE_COLOR"                      value="2E2222"/>

    <!-- Folded text -->
    <option name="FOLDED_TEXT_BORDER_COLOR"            value="3A2A2A"/>

    <!-- Identifier under caret: red tint for read, green tint for write -->
    <option name="IDENTIFIER_UNDER_CARET_COLOR"        value="281E1E"/>
    <option name="WRITE_IDENTIFIER_UNDER_CARET_COLOR"  value="081828"/>

    <!-- Search results — bright enough to stand out on #1C1A1A (contrast ≥3:1 vs bg, ≥4.5:1 vs fg) -->
    <option name="SEARCH_RESULT_SELECTION_COLOR"       value="B8346E"/>
    <option name="WRITE_SEARCH_RESULT_SELECTION_COLOR" value="157080"/>

    <!-- VCS gutter indicators — Red/Green/Orange (NO blue) -->
    <option name="ADDED_LINES_COLOR"                   value="081820"/>
    <option name="MODIFIED_LINES_COLOR"                value="3A2000"/>
    <option name="DELETED_LINES_COLOR"                 value="3A0A0A"/>
    <option name="IGNORED_ADDED_LINES_BORDER_COLOR"    value="0A2838"/>
    <option name="IGNORED_MODIFIED_LINES_BORDER_COLOR" value="5A2A00"/>
    <option name="IGNORED_DELETED_LINES_BORDER_COLOR"  value="5A1A1A"/>
    <option name="DIFF_SEPARATING_CHANGES_COLOR"       value="3A2A2A"/>
  </colors>

  <!-- ═══════════════════════════════════════════════════
       SEMANTIC ATTRIBUTES
       ═══════════════════════════════════════════════════ -->
  <attributes>

    <!-- ─── Default Text ───────────────────────────────── -->
    <option name="TEXT">
      <value>
        <option name="FOREGROUND"  value="E8E4E0"/>
        <option name="BACKGROUND"  value="1C1A1A"/>
        <option name="FONT_TYPE"   value="0"/>
      </value>
    </option>

    <!-- ─── Diagnostics (triple / double encoding) ──────── -->

    <!-- ERRORS: red fg + bold + squiggly underline + stripe marker -->
    <option name="ERRORS_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="FF4444"/>
        <option name="EFFECT_TYPE"        value="2"/>  <!-- 2 = wave/squiggly -->
        <option name="ERROR_STRIPE_COLOR" value="FF4444"/>
        <option name="FONT_TYPE"          value="1"/>  <!-- bold -->
      </value>
    </option>

    <!-- Unresolved symbols: red fg + squiggly -->
    <option name="WRONG_REFERENCES_ATTRIBUTES">
      <value>
        <option name="FOREGROUND"         value="FF4444"/>
        <option name="EFFECT_COLOR"       value="FF4444"/>
        <option name="EFFECT_TYPE"        value="2"/>
        <option name="ERROR_STRIPE_COLOR" value="FF4444"/>
      </value>
    </option>

    <!-- WARNINGS: orange squiggly underline + stripe marker, no text color/weight change -->
    <option name="WARNING_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="FFA040"/>
        <option name="EFFECT_TYPE"        value="2"/>  <!-- 2 = wave/squiggly -->
        <option name="ERROR_STRIPE_COLOR" value="FFA040"/>
      </value>
    </option>

    <!-- INFO: muted rose + dotted underline -->
    <option name="INFO_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="B07878"/>
        <option name="EFFECT_TYPE"        value="6"/>
        <option name="ERROR_STRIPE_COLOR" value="B07878"/>
      </value>
    </option>

    <!-- WEAK WARNING: lighter dotted underline, no stripe -->
    <option name="WEAK_WARNING_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="9A8878"/>
        <option name="EFFECT_TYPE"        value="6"/>
      </value>
    </option>

    <!-- SERVER ERROR: red, boxed outline for visibility -->
