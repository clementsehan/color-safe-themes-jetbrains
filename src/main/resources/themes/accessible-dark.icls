        <option name="FONT_TYPE"   value="1"/>  <!-- bold — same register as keywords -->
      </value>
    </option>

    <option name="DEFAULT_ATTRIBUTE">
      <value>
        <option name="FOREGROUND"  value="C8B0E0"/>
        <option name="FONT_TYPE"   value="2"/>  <!-- italic — structural encoding -->
      </value>
    </option>

    <option name="DEFAULT_ENTITY">
