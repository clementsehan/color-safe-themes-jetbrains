      </value>
    </option>

    <option name="DEFAULT_DOC_COMMENT_TAG_VALUE">
      <value>
        <option name="FOREGROUND"  value="A8A8C8"/>
        <option name="FONT_TYPE"   value="2"/>
      </value>
    </option>

    <option name="DEFAULT_DOC_MARKUP">
