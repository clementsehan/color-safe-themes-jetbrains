<?xml version="1.0" encoding="UTF-8"?>
<scheme name="Pro-Deutan Dark" version="142" parent_scheme="Darcula">

  <!--
    Accessible Dark (CVD) — Editor Color Scheme
    Designed for Protanopia &amp; Deuteranopia (Red-Green Color Blindness)

    Core axis: Blue (#5BB8F5) vs Amber (#E6A020) — NOT red vs green.
    Errors:    Hot Pink/Magenta (#FF5F87) + squiggly underline + bold (triple encoding).
    Warnings:  Amber-Orange (#FFAB40) + dotted underline (double encoding).
    Comments:  Italic — distinct font style regardless of color perception.
    Keywords:  Bold — structurally distinct regardless of color perception.

    All text-on-background contrast ratios verified ≥ 4.5:1 (WCAG AA).

    Contrast calculations against editor bg #1C1C2E (L ≈ 0.013):
      #E2E2F0  → 13.0:1   #5BB8F5  →  7.65:1  #E6A020  →  7.44:1
      #F0D060  → 11.0:1   #80CCE8  →  9.3:1   #A8D8F0  → 10.9:1
      #C8B0E0  →  8.5:1   #FFAB40  →  8.84:1  #FF5F87  →  5.75:1
      #9CA3C8  →  6.77:1  #7890B8  →  5.08:1  #78D8F0  → 10.2:1
      (comments upgraded from #8888B0 4.92:1 → #9CA3C8 6.77:1, near AAA)
  -->

  <!-- ═══════════════════════════════════════════════════
       GLOBAL COLORS
       ═══════════════════════════════════════════════════ -->
  <colors>
    <!-- Core editor surface -->
    <option name="BACKGROUND"                          value="1C1C2E"/>
    <option name="FOREGROUND"                          value="E2E2F0"/>
    <option name="CARET_COLOR"                         value="5BB8F5"/>
    <option name="CARET_ROW_COLOR"                     value="1E2840"/>
    <option name="READONLY_BACKGROUND"                 value="18182A"/>
    <option name="READONLY_FRAGMENT_BACKGROUND"        value="22223A"/>

    <!-- Gutter -->
    <option name="GUTTER_BACKGROUND"                   value="1A1A2E"/>
    <option name="LINE_NUMBERS_COLOR"                  value="7890B8"/>
    <option name="LINE_NUMBER_ON_CARET_ROW_COLOR"      value="A8A8C8"/>

    <!-- Selection -->
    <option name="SELECTION_BACKGROUND"                value="3A3A72"/>
    <option name="SELECTION_FOREGROUND"                value="E2E2F0"/>

    <!-- Right margin / guide lines -->
    <option name="RIGHT_MARGIN_COLOR"                  value="2E2E50"/>
    <option name="INDENT_GUIDE"                        value="2E2E50"/>
    <option name="SELECTED_INDENT_GUIDE"               value="5BB8F5"/>
    <option name="WHITESPACE"                          value="363660"/>
    <option name="METHOD_SEPARATORS_COLOR"             value="2E2E50"/>
    <option name="TEARLINE_COLOR"                      value="2E2E50"/>

    <!-- Folded text -->
    <option name="FOLDED_TEXT_BORDER_COLOR"            value="363660"/>

    <!-- Identifier under caret: blue highlight for read, amber for write -->
    <option name="IDENTIFIER_UNDER_CARET_COLOR"        value="1E2840"/>
    <option name="WRITE_IDENTIFIER_UNDER_CARET_COLOR"  value="2A2800"/>

    <!-- Search results -->
    <option name="SEARCH_RESULT_SELECTION_COLOR"       value="2A3A00"/>
    <option name="WRITE_SEARCH_RESULT_SELECTION_COLOR" value="3A2800"/>

    <!-- VCS gutter indicators — using Blue/Amber/Pink (NOT green/red) -->
    <option name="ADDED_LINES_COLOR"                   value="1E3A6A"/>
    <option name="MODIFIED_LINES_COLOR"                value="4A3200"/>
    <option name="DELETED_LINES_COLOR"                 value="5A1030"/>
    <option name="IGNORED_ADDED_LINES_BORDER_COLOR"    value="2A4A7A"/>
    <option name="IGNORED_MODIFIED_LINES_BORDER_COLOR" value="6A4800"/>
    <option name="IGNORED_DELETED_LINES_BORDER_COLOR"  value="7A1A40"/>
    <option name="DIFF_SEPARATING_CHANGES_COLOR"       value="363660"/>
  </colors>

  <!-- ═══════════════════════════════════════════════════
       SEMANTIC ATTRIBUTES
       ═══════════════════════════════════════════════════ -->
  <attributes>

    <!-- ─── Default Text ───────────────────────────────── -->
    <option name="TEXT">
      <value>
        <option name="FOREGROUND"  value="E2E2F0"/>
        <option name="BACKGROUND"  value="1C1C2E"/>
        <option name="FONT_TYPE"   value="0"/>
      </value>
    </option>

    <!-- ─── Diagnostics (triple / double encoding) ──────── -->

    <!-- ERRORS: magenta fg + bold + squiggly underline + stripe marker -->
    <option name="ERRORS_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="FF5F87"/>
        <option name="EFFECT_TYPE"        value="2"/>  <!-- 2 = wave/squiggly -->
        <option name="ERROR_STRIPE_COLOR" value="FF5F87"/>
        <option name="FONT_TYPE"          value="1"/>  <!-- bold -->
      </value>
    </option>

    <!-- Unresolved symbols: magenta fg + squiggly (distinct from compile error) -->
    <option name="WRONG_REFERENCES_ATTRIBUTES">
      <value>
        <option name="FOREGROUND"         value="FF5F87"/>
        <option name="EFFECT_COLOR"       value="FF5F87"/>
        <option name="EFFECT_TYPE"        value="2"/>
        <option name="ERROR_STRIPE_COLOR" value="FF5F87"/>
      </value>
    </option>

    <!-- WARNINGS: amber + bold-dotted underline + stripe marker -->
    <option name="WARNING_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="FFAB40"/>
        <option name="EFFECT_TYPE"        value="6"/>  <!-- 6 = bold dotted underline -->
        <option name="ERROR_STRIPE_COLOR" value="FFAB40"/>
        <option name="FONT_TYPE"          value="1"/>  <!-- bold -->
      </value>
    </option>

    <!-- INFO: steel blue + regular dotted underline -->
    <option name="INFO_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="7890B8"/>
        <option name="EFFECT_TYPE"        value="6"/>
        <option name="ERROR_STRIPE_COLOR" value="7890B8"/>
      </value>
    </option>

    <!-- WEAK WARNING: lighter dotted underline, no stripe -->
    <option name="WEAK_WARNING_ATTRIBUTES">
      <value>
        <option name="EFFECT_COLOR"       value="8888B0"/>
        <option name="EFFECT_TYPE"        value="6"/>
      </value>
    </option>

    <!-- SERVER ERROR: brighter magenta, boxed outline for visibility -->
    <option name="SERVER_ERROR_OR_WARNING">
      <value>
        <option name="EFFECT_COLOR"       value="FF5F87"/>
        <option name="EFFECT_TYPE"        value="1"/>  <!-- 1 = box/border -->
        <option name="ERROR_STRIPE_COLOR" value="FF5F87"/>
      </value>
    </option>

    <!-- DEPRECATED: gray + strikethrough (structural encoding) -->
    <option name="DEPRECATED_ATTRIBUTES">
      <value>
        <option name="FOREGROUND"         value="8888B0"/>
        <option name="EFFECT_COLOR"       value="8888B0"/>
        <option name="EFFECT_TYPE"        value="3"/>  <!-- 3 = strikethrough -->
      </value>
    </option>

    <!-- ─── Keywords ──────────────────────────────────── -->

    <!-- Default keyword: sky blue + bold -->
    <option name="DEFAULT_KEYWORD">
      <value>
        <option name="FOREGROUND"  value="5BB8F5"/>
        <option name="FONT_TYPE"   value="1"/>
      </value>
    </option>

    <!-- Java-specific: inherits DEFAULT_KEYWORD -->
    <option name="JAVA_KEYWORD">
      <value>
        <option name="FOREGROUND"  value="5BB8F5"/>
        <option name="FONT_TYPE"   value="1"/>
      </value>
    </option>

    <!-- ─── Strings ───────────────────────────────────── -->

    <!-- Default string: amber -->
    <option name="DEFAULT_STRING">
      <value>
        <option name="FOREGROUND"  value="E6A020"/>
        <option name="FONT_TYPE"   value="0"/>
      </value>
    </option>

    <option name="DEFAULT_STRING_ESCAPE">
      <value>
        <option name="FOREGROUND"  value="FFAB40"/>
        <option name="FONT_TYPE"   value="1"/>
      </value>
    </option>

    <option name="DEFAULT_INVALID_STRING_ESCAPE">
      <value>
        <option name="FOREGROUND"         value="FF5F87"/>
        <option name="EFFECT_COLOR"       value="FF5F87"/>
        <option name="EFFECT_TYPE"        value="2"/>
        <option name="FONT_TYPE"          value="1"/>
      </value>
    </option>

    <option name="DEFAULT_VALID_STRING_ESCAPE">
      <value>
        <option name="FOREGROUND"  value="80CCE8"/>
        <option name="FONT_TYPE"   value="1"/>
      </value>
    </option>

    <!-- ─── Numbers ──────────────────────────────────── -->

    <option name="DEFAULT_NUMBER">
      <value>
        <option name="FOREGROUND"  value="F0D060"/>
        <option name="FONT_TYPE"   value="0"/>
      </value>
    </option>

    <!-- ─── Comments (italic for structural double-encoding) ─ -->

    <option name="DEFAULT_LINE_COMMENT">
      <value>
        <option name="FOREGROUND"  value="9CA3C8"/>
        <option name="FONT_TYPE"   value="2"/>
      </value>
    </option>

    <option name="DEFAULT_BLOCK_COMMENT">
