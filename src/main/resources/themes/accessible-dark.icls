    </option>

    <option name="DEFAULT_STATIC_FIELD">
      <value>
        <option name="FOREGROUND"  value="F0D060"/>
        <option name="FONT_TYPE"   value="3"/>  <!-- bold italic -->
      </value>
    </option>

    <option name="DEFAULT_INSTANCE_FIELD">
      <value>
        <option name="FOREGROUND"  value="C8B0E0"/>
        <option name="FONT_TYPE"   value="0"/>
      </value>
    </option>

    <option name="DEFAULT_LOCAL_VARIABLE">
      <value>
        <option name="FOREGROUND"  value="E2E2F0"/>
        <option name="FONT_TYPE"   value="0"/>
      </value>
    </option>

    <option name="DEFAULT_PARAMETER">
      <value>
        <option name="FOREGROUND"  value="C8B0E0"/>
        <option name="FONT_TYPE"   value="2"/>  <!-- italic — structural encoding -->
      </value>
    </option>

    <option name="DEFAULT_GLOBAL_VARIABLE">
      <value>
        <option name="FOREGROUND"  value="C8B0E0"/>
        <option name="FONT_TYPE"   value="1"/>
      </value>
    </option>

